/* 引入icon样式库 */
@import '/style/icons.wxss';
@import '/style/common.wxss';
@import '/style/color.wxss';

/* 【新增】夜间模式变量定义 */

/* 亮色模式 */
.theme-light {
  --bg-color: #ffffff;         /* 背景色 */
  --bg-secondary: #f5f5f5;    /* 搜索框/输入框背景 */
  --text-main: #333333;       /* 主标题色 */
  --text-gray: #999999;       /* 辅助描述色 */
  --border-color: #eeeeee;    /* 分割线颜色 */
  --item-bg: #ffffff;         /* 选项卡背景 */
}

/* 暗色模式 */
.theme-dark {
  --bg-color: #1a1a1a;
  --bg-secondary: #2d2d2d;
  --text-main: #e0e0e0;
  --text-gray: #888888;
  --border-color: #333333;
  --item-bg: #242424;
}

/* 全局基础包裹层样式 */
.page-wrapper {
  background-color: var(--bg-color);
  min-height: 100vh;
  color: var(--text-main);
  transition: all 0.3s ease; /* 平滑切换动画 */
}

/* 兼容处理：确保全局的 text 组件在夜间模式下也能识别变量 */
.text-main { color: var(--text-main); }
.text-gray { color: var(--text-gray); }