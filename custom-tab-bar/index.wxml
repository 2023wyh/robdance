<view class="tab-bar theme-{{theme}}">
  <view class="tab-bar-border"></view>
  <view wx:for="{{list}}" wx:key="index" class="tab-bar-item" data-path="{{item.pagePath}}" data-index="{{index}}" bindtap="switchTab">
    <image class="tab-image" src="{{selected === index ? item.selectedIconPath : item.iconPath}}"></image>
    <view class="tab-text" style="color: {{selected === index ? selectedColor : 'var(--text-gray)'}}">{{item.text}}</view>
  </view>
</view>