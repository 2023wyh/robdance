page {
  background-color: #f6f7f9;
}

.container {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
}

/* 头部信息 */
.header {
  margin-bottom: 40rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
}

/* 媒体预览区 */
.media-preview-container {
  width: 100%;
  height: 500rpx;
  background-color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  position: relative;
  margin-bottom: 40rpx;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #ccc;
}

/* 用一个简单的方块当作图标占位 */
.icon-camera {
  width: 80rpx;
  height: 80rpx;
  background-color: #f0f0f0;
  border-radius: 50%;
  margin-bottom: 20rpx;
  position: relative;
}
.icon-camera::after {
  content: "+";
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 50rpx;
  color: #999;
}

.tip-text {
  font-size: 22rpx;
  margin-top: 10rpx;
}

.preview-media {
  width: 100%;
  height: 100%;
}

.reselect-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
}

/* 结果区 */
.result-container {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 150rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid #eee;
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.score-box {
  color: #ff520f;
}

.score-number {
  font-size: 48rpx;
  font-weight: bold;
}

.score-unit {
  font-size: 24rpx;
  margin-left: 4rpx;
}

.result-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-item {
  display: flex;
  font-size: 28rpx;
}

.item-label {
  color: #666;
  width: 180rpx;
}

.item-value {
  color: #333;
  font-weight: bold;
}

.result-suggestion {
  margin-top: 10rpx;
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 12rpx;
}

.suggestion-title {
  display: block;
  font-size: 28rpx;
  color: #ff520f;
  margin-bottom: 10rpx;
  font-weight: bold;
}

.suggestion-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
}

/* 底部按钮 */
.footer-action {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20rpx 40rpx;
  background-color: #fff;
  box-shadow: 0 -4rpx 10rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.action-btn {
  background: linear-gradient(to right, #ff7a38, #ff520f);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  width: 100%;
}

.action-btn.disabled {
  background: #ccc;
  color: #fff;
}

/* 骨架画布 */
.skeleton-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none; /* 让画布不阻挡下方元素的点击 */
  z-index: 10;
}

/* 详细关节诊断 */
.detail-analysis {
  margin-top: 10rpx;
  background-color: #f0f4f8;
  padding: 20rpx;
  border-radius: 12rpx;
}

.detail-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  border-left: 6rpx solid #ff520f;
  padding-left: 10rpx;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-item {
  display: flex;
  font-size: 26rpx;
  align-items: flex-start;
  line-height: 1.4;
}

.detail-name {
  color: #555;
  width: 130rpx;
  flex-shrink: 0;
}

.detail-status {
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-right: 16rpx;
  font-weight: bold;
  white-space: nowrap;
}

.status-good {
  background-color: #e6f7ef;
  color: #07c160;
}

.status-bad {
  background-color: #ffeee6;
  color: #fa5151;
}

.detail-desc {
  color: #666;
  flex: 1;
}
