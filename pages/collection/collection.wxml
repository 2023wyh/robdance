<!-- pages/collection/collection.wxml -->
<view class="page-wrapper theme-{{theme}}">
	<!-- 若是没有登录就显示登录界面 -->
	<block wx:if="{{!login}}">
		<view class="hmly-logo">
			<image class="hmly-logo-img" src="/image/logo.png" mode="widthFix"></image>
		</view>
		<view class="hmly-login-button">
			<view class="hmly-wechat-login">
				<button open-type="getUserInfo" bindgetuserinfo="bindGetUserInfo">
					<text class="icon-message"></text> 微信登录
				</button>
			</view>
			<view class="hmly-phone-login">
				<button>手机号登录</button>
			</view>
		</view>
	</block>

	<!-- 已登录界面 -->
	<block wx:else>
		<!-- 搜索框 -->
		<search theme="{{theme}}"></search>
		
		<!-- 功能栏 (选项卡标题) -->
		<view class="hmly-title-bar" style="background-color: var(--bg-color); border-bottom: 1rpx solid var(--border-color);">
			<view 
				class="hmly-item-title {{index == currentIndex ? 'hmly-active' : ''}}" 
				style="color: {{index == currentIndex ? '#ff520f' : 'var(--text-gray)'}};"
				data-index="{{index}}"
				bindtap="checkItem" 
				wx:for="{{content}}" 
				wx:key="index"
			>
				{{item.text}}
			</view>
		</view>

		<swiper class="hmly-swiper-box" style="height:{{height}}px; background-color: var(--bg-color);" duration="300" current="{{currentIndex}}" bindchange="changeTab">
			<!-- 这里演示第一个 swiper-item，其他三个同理修改 -->
			<swiper-item wx:for="{{content}}" wx:key="index">
				<view class="hmly-no-content">
					<!-- 修改点：图标颜色和文字颜色 -->
					<text class="icon-empty" style="font-size:400rpx; color: var(--bg-secondary);"></text>
					<view class="hmly-but-box">
						<text style="font-size:30rpx; color: var(--text-gray);">没有内容</text>
						<!-- 修改点：按钮样式 -->
						<button class="hmly-but" style="background-color: #ff520f; color: #fff;">
							{{index === 3 ? '更多礼包' : '看看推荐'}}
						</button>
					</view>
				</view>
			</swiper-item>
		</swiper>
	</block>
</view>