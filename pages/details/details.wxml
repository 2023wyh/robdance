<!-- pages/details/details.wxml -->
<view class="page-wrapper theme-{{theme}}">
	<!-- 顶部标题栏 -->
	<view class="hmly-top-title-bar">
		<!-- 背景虚化层 -->
		<view class="hmly-bg" style="background:url({{imgurl}}); background-size: 100% 100%; background-repeat: no-repeat;" />
		<!-- 内容区：顶部这部分通常文字固定为白色以适应深色虚化背景，可以保留内联白色 -->
		<view class="hmly-bar-item" wx:for="{{performanceInfo}}" wx:key="index">
			<view class="hmly-bar-item-top">
				<view class="hmly-theme-bg-img" style="background:url({{item.imgurl}}); background-size:100% 100%"></view>
				<view class="hmly-theme-info">
					<view class="hmly-theme-title" style="color: #fff;">{{item.title}}</view>
					<view class="hmly-theme-author" style="color: #eee;">
						{{item.author}} <text class="icon-right"></text>
					</view>
					<view class="hmly-view-info" style="color: #ddd;">
						<view class="hmly-view-info-left">{{item.num1}}人收藏</view>
						<text class="hmly-viewhmly-info-mid">|</text>
						<view class="hmly-view-info-right">已更新{{item.num2}}期</view>
					</view>
				</view>
			</view>
			<view class="hmly-bar-item-bottom">
				<button class="hmly-share-but"><text class="icon-share"></text> 分享</button>
				<button class="hmly-collection"><text class="icon-add"></text> 收藏</button>
			</view>
		</view>
	</view>

	<!-- 节目列表部分 (这部分需要严格适配夜间模式) -->
	<view class="hmly-performance" style="background-color: var(--bg-color);">
		<!-- 选项卡 -->
		<view class="hmly-selectbar" style="border-bottom: 1rpx solid var(--border-color);">
			<view class="hmly-detail" style="color: var(--text-gray);">详情</view>
			<view class="hmly-list hmly-active">节目<text style="margin-left:10rpx">152</text></view>
		</view>

		<!-- 播放全部栏 -->
		<view class="hmly-play" style="background-color: var(--bg-color);">
			<view class="hmly-play-all" style="color: var(--text-main);">
				<text class="icon-video" style="color: #ff520f;"></text> 播放全部
			</view>
			<view class="hmly-play-select" style="color: var(--text-gray);">
				<view style="margin-right:20rpx"><text class="icon-order"></text> 正序</view>
				<view><text class="icon-list"></text> 选集</view>
			</view>
		</view>

		<!-- 节目列表循环 -->
		<view class="hmly-performance-content" wx:for="{{performance}}" wx:key="index" style="border-bottom: 1rpx solid var(--border-color);">
			<!-- 序号 -->
			<view class="hmly-performance-index" style="color: var(--text-gray);">{{index+1}}</view>
			<!-- 节目标题信息 -->
			<view class="hmly-performance-info">
				<view class="hmly-performance-info-top">
					<view style="font-size:33rpx; color: var(--text-main);">{{item.name}}</view>
					<view style="color: var(--text-gray);">{{item.year}}</view>
				</view>
				<!-- 播放次数和时间 -->
				<view class="hmly-performance-info-bottom" style="color: var(--text-gray);">
					<view><text class="icon-video"></text> {{item.count}}</view>
					<view style="margin-left:20rpx"><text class="icon-time"></text> {{item.time}}</view>
				</view>
			</view>
		</view>
	</view>
	
	<!-- 底部填充，避免二级页面底部内容靠边不美观 -->
	<view style="height: 50rpx; background-color: var(--bg-color);"></view>
</view>