<!-- pages/classification/classification.wxml -->
<view class="page-wrapper theme-{{theme}}">
	<!-- 搜索框 -->
	<search theme="{{theme}}"></search>

	<!-- 分类索引容器 -->
	<view class="hmly-ification">
		<!-- 左边部分 (通常背景色稍深于右侧) -->
		<scroll-view 
			class="hmly-scroll-left" 
			scroll-y 
			scroll-with-animation 
			style="height:{{phoneHeight}}rpx; background-color: var(--bg-secondary);"
			scroll-top="{{VerticalNavTop}}"
		>
			<block wx:for="{{ificationTitle}}" wx:key="index">
				<view 
					class="hmly-left-title {{index === activeIndex ? 'hmly-active' : ''}}" 
					style="color: {{index === activeIndex ? '#ff520f' : 'var(--text-gray)'}};"
					data-index="{{index}}"
					data-id="{{index}}" 
					bindtap="change"
				>
					{{item.title}}
				</view>
			</block>
		</scroll-view>

		<!-- 右边部分 -->
		<scroll-view 
			class="hmly-scroll-right" 
			scroll-y 
			bindscroll="showActive" 
			style="height:{{phoneHeight}}rpx; background-color: var(--bg-color);"
			scroll-into-view="main-id-{{TabCur}}"
		>
			<view class="hmly-content-scroll-item" wx:for="{{ificationContent}}" wx:key="index" data-index="{{index}}" id="main-id-{{index}}">
				<!-- 右侧小标题 -->
				<view class="hmly-top" style="color: var(--text-main);">
					{{item.title}}
					<text class="icon-right"></text>
				</view>
				<!-- 右侧网格内容 -->
				<view class="hmly-content">
					<view 
						class="hmly-content-text" 
						wx:for="{{item.content}}" 
						wx:key="index"
						style="background-color: var(--bg-secondary); color: var(--text-main);"
					>
						{{item.text}}
					</view>
				</view>
			</view>
			<!-- 底部占位，防止 TabBar 遮挡内容 -->
			<view style="height: 120rpx;"></view>
		</scroll-view>
	</view>
</view>