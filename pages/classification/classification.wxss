/* pages/classification/classification.wxss */

/* ---------- 原有样式（保留） ---------- */
.hmly-ification {
  width: 100%;
  height: 100%;
  background-color: rgb(243, 244, 246);
  display: flex;
  justify-content: start;
}

.hmly-scroll-left {
  width: 22%;
  padding-top: 55rpx;
  margin-right: 20rpx;
  background-color: #fff;
  overflow: hidden;
}

.hmly-left-title {
  text-align: center;
  font-size: 28rpx;
  height: 100rpx;
  line-height: 100rpx;
}

.hmly-scroll-right {
  width: 75%;
}

.hmly-active {
  color: #ff520f;
  background-color: rgb(243, 244, 246);
}

.hmly-content-scroll-item {
  width: auto;
  height: auto;
  margin-bottom: 20rpx;
}

.hmly-top {
  width: 100%;
  height: 40rpx;
  padding: 20rpx 0rpx;
  margin: 0rpx auto;
  font-size: center;
  display: flex;
  justify-content: center;
  align-items: center;
}

.hmly-content-title {
  color: rgb(12, 11, 11);
  font-size: 30rpx;
  text-align: center;
  margin: 0rpx auto;
}

.hmly-content {
  width: 100%;
  height: 140rpx;
  padding: 30rpx 0rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-content: space-around;
  justify-content: space-between;
  background-color: #fff;
  border-top-left-radius: 7rpx;
  border-bottom-left-radius: 7rpx;
}

.hmly-content-text {
  width: 130rpx;
  height: 50rpx;
  margin: 10rpx 20rpx;
  font-size: 30rpx;
  text-align: center;
}

/* ---------- 新增样式（课程页） ---------- */

/* 搜索输入 */
.search-wrap {
  padding: 18rpx 20rpx;
  background: #fff;
}
.search-input {
  width: 100%;
  height: 68rpx;
  border-radius: 34rpx;
  padding: 0 28rpx;
  background: #f5f5f5;
  border: none;
  font-size: 26rpx;
}

/* 顶部 tab 样式 */
.course-tabbar {
  display: flex;
  padding: 18rpx 20rpx;
  background: #fff;
  overflow-x: auto;
  white-space: nowrap;
  border-bottom: 1rpx solid #f0f0f0;
  -webkit-overflow-scrolling: touch;
}
.tab-item {
  padding: 12rpx 28rpx;
  margin-right: 12rpx;
  border-radius: 28rpx;
  font-size: 28rpx;
  color: #666;
  background: #f8f8f8;
  white-space: nowrap;
}
.tab-item.active {
  color: #fff;
  background: #ff520f; /* 与 app.json 选中色保持一致 */
}

/* 舞种筛选条（横向） */
.dance-style-bar {
  display: flex;
  padding: 12rpx 18rpx;
  gap: 14rpx;
  background: #fff;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

/* 每个舞种项样式 */
.style-item {
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  background: #f4f4f4;
  color: #666;
  font-size: 26rpx;
  white-space: nowrap;
}

/* 被选中时的样式（高亮） */
.style-item.active {
  background: #ff520f; /* 与 app.json selectedColor 保持一致 */
  color: #fff;
}

/* 列表容器 */
.course-list-wrap {
  padding: 20rpx;
  background: #fafafa;
  min-height: 600rpx;
}

/* 空提示 */
.empty-tip {
  text-align: center;
  color: #999;
  padding: 120rpx 0;
}

/* 网格布局 */
.course-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: space-between;
}

/* 卡片 */
.course-card {
  width: 48%;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.04);
  margin-bottom: 20rpx;
}
.cover {
  width: 100%;
  height: 260rpx;
  display: block;
}
.card-body {
  padding: 18rpx;
}
.title {
  font-size: 28rpx;
  color: #333;
  line-height: 36rpx;
  height: 72rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}
.meta {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
}
.dance {
  color: #666;
}
.price {
  color: #ff520f;
  font-weight: 600;
}

/* 标签 */
.tags {
  margin-top: 10rpx;
}
.tag-text {
  display: inline-block;
  padding: 6rpx 12rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
  border-radius: 12rpx;
  background: #f2f2f2;
  font-size: 22rpx;
  color: #666;
}

/* 响应式微调：窄屏时让卡片变成单列 */
@media screen and (max-width: 360px) {
  .course-card { width: 100%; }
}

/* ---------- 新增：封面容器与角标样式 ---------- */

/* 封面容器（把 cover 放进这个容器以支持角标/遮罩） */
.cover-wrap {
  position: relative;
  width: 100%;
  height: 260rpx;
  overflow: hidden;
}

/* 角标（左上角） */
.corner-label {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 20rpx;
  z-index: 2;
}

/* 可选：封面底部渐变遮罩（让标题更好看） */
.cover-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 80rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.45) 100%);
  z-index: 1;
}

/* 小播放图标浮层（可选，放在封面正中） */
.play-icon {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 2;
  font-size: 46rpx;
  color: rgba(255,255,255,0.92);
}

/* 卡片主体与标题在封面遮罩上显示更清晰 */
.card-body { padding: 18rpx; }
.title { font-size: 28rpx; color: #fff; /* 如果你把标题放在遮罩上 */ }

/* 若你希望把标题显示在封面底部遮罩上，可以额外样式（注释掉可选使用）
.cover-title {
  position: absolute;
  left: 16rpx;
  bottom: 12rpx;
  z-index: 2;
  color: #fff;
  font-size: 26rpx;
}
*/

/* 如果你想给角标不同颜色，可以通过 .corner-label.vip / .corner-label.live 等覆盖 */
.corner-label.vip { background: rgba(255,82,15,0.95); }
.corner-label.live { background: rgba(10,140,255,0.95); }
.corner-label.offline { background: rgba(123,97,255,0.95); }