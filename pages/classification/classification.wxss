/* pages/classification/classification.wxss */

/* ---------- 原有样式（适配变量） ---------- */
.hmly-ification {
  width: 100%;
  height: 100%;
  background-color: var(--bg-secondary); /* 替换 rgb(243, 244, 246) */
  display: flex;
  justify-content: start;
}

.hmly-scroll-left {
  width: 22%;
  padding-top: 55rpx;
  margin-right: 20rpx;
  background-color: var(--bg-color); /* 替换 #fff */
  overflow: hidden;
}

.hmly-left-title {
  text-align: center;
  font-size: 28rpx;
  height: 100rpx;
  line-height: 100rpx;
  color: var(--text-main); /* 新增：文字颜色 */
}

.hmly-scroll-right {
  width: 75%;
}

.hmly-active {
  color: #ff520f;
  background-color: var(--bg-secondary); /* 替换 rgb(243, 244, 246) */
}

.hmly-content-scroll-item {
  width: auto;
  height: auto;
  margin-bottom: 20rpx;
}

.hmly-top {
  width: 100%;
  height: 40rpx;
  padding: 20rpx 0rpx;
  margin: 0rpx auto;
  font-size: center;
  display: flex;
  justify-content: center;
  align-items: center;
  color: var(--text-main); /* 新增：文字颜色 */
}

.hmly-content-title {
  color: var(--text-main); /* 替换 rgb(12, 11, 11) */
  font-size: 30rpx;
  text-align: center;
  margin: 0rpx auto;
}

.hmly-content {
  width: 100%;
  height: 140rpx;
  padding: 30rpx 0rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-content: space-around;
  justify-content: space-between;
  background-color: var(--bg-color); /* 替换 #fff */
  border-top-left-radius: 7rpx;
  border-bottom-left-radius: 7rpx;
}

.hmly-content-text {
  width: 130rpx;
  height: 50rpx;
  margin: 10rpx 20rpx;
  font-size: 30rpx;
  text-align: center;
  color: var(--text-gray); /* 新增：辅助文字颜色 */
}

/* ---------- 新增样式（课程页适配） ---------- */

/* 搜索输入 */
.search-wrap {
  padding: 18rpx 20rpx;
  background-color: var(--bg-color); /* 替换 #fff */
}
.search-input {
  width: 100%;
  height: 68rpx;
  border-radius: 34rpx;
  padding: 0 28rpx;
  background-color: var(--bg-secondary); /* 替换 #f5f5f5 */
  border: none;
  font-size: 26rpx;
  color: var(--text-main); /* 新增：输入文字颜色 */
}

/* 顶部分类 tab 样式 */
.course-tabbar {
  display: flex;
  padding: 18rpx 20rpx;
  background-color: var(--bg-color); /* 替换 #fff */
  overflow-x: auto;
  white-space: nowrap;
  border-bottom: 1rpx solid var(--border-color); /* 替换 #f0f0f0 */
  -webkit-overflow-scrolling: touch;
}
.tab-item {
  padding: 12rpx 28rpx;
  margin-right: 12rpx;
  border-radius: 28rpx;
  font-size: 28rpx;
  color: var(--text-gray); /* 替换 #666 */
  background-color: var(--bg-secondary); /* 替换 #f8f8f8 */
  white-space: nowrap;
}
.tab-item.active {
  color: #fff; /* 品牌色上的字通常保持白色 */
  background-color: #ff520f; 
}

/* 舞种筛选条（横向） */
.dance-style-bar {
  display: flex;
  padding: 12rpx 18rpx;
  gap: 14rpx;
  background-color: var(--bg-color); /* 替换 #fff */
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

/* 每个舞种项样式 */
.style-item {
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  background-color: var(--bg-secondary); /* 替换 #f4f4f4 */
  color: var(--text-gray); /* 替换 #666 */
  font-size: 26rpx;
  white-space: nowrap;
}

/* 被选中时的样式（高亮） */
.style-item.active {
  background-color: #ff520f; 
  color: #fff;
}

/* 列表容器 */
.course-list-wrap {
  padding: 20rpx;
  background-color: var(--bg-color); /* 替换 #fafafa */
  min-height: 600rpx;
}

/* 空提示 */
.empty-tip {
  text-align: center;
  color: var(--text-gray); /* 替换 #999 */
  padding: 120rpx 0;
}

/* 网格布局 */
.course-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: space-between;
}

/* 卡片 */
.course-card {
  width: 48%;
  background-color: var(--bg-secondary); /* 重要：夜间模式卡片通常比背景略亮 */
  border-radius: 12rpx;
  overflow: hidden;
  /* 夜间模式阴影需要变淡或取消，使用 border 更有质感 */
  border: 1rpx solid var(--border-color); 
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.04);
  margin-bottom: 20rpx;
}
.cover {
  width: 100%;
  height: 260rpx;
  display: block;
}
.card-body {
  padding: 18rpx;
}
.title {
  font-size: 28rpx;
  color: var(--text-main); /* 替换 #333 */
  line-height: 36rpx;
  height: 72rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}
.meta {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text-gray); /* 替换 #999 */
}
.dance {
  color: var(--text-gray); /* 替换 #666 */
}
.price {
  color: #ff520f;
  font-weight: 600;
}

/* 标签 */
.tags {
  margin-top: 10rpx;
}
.tag-text {
  display: inline-block;
  padding: 6rpx 12rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
  border-radius: 12rpx;
  background-color: var(--bg-color); /* 替换 #f2f2f2 */
  font-size: 22rpx;
  color: var(--text-gray); /* 替换 #666 */
}

/* 响应式微调 */
@media screen and (max-width: 360px) {
  .course-card { width: 100%; }
}

/* ---------- 封面容器与角标样式适配 ---------- */

.cover-wrap {
  position: relative;
  width: 100%;
  height: 260rpx;
  overflow: hidden;
}

/* 角标：由于在图片上，颜色可以保持固定 */
.corner-label {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 20rpx;
  z-index: 2;
}

/* 针对夜间模式的微调：如果需要可以在这里添加 .theme-dark 类下的特殊覆盖 */